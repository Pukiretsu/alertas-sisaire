# =================================================================
# ARCHIVO DE CONFIGURACIÓN DE EJEMPLO (.env.example)
# Instrucciones: Copia este archivo como '.env' y completa los datos.
# =================================================================

# --- CONFIGURACIÓN DE BASE DE DATOS (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=calidad_aire_db
DB_USER=tu_usuario_aqui
DB_PASSWORD=tu_contraseña_aqui

# --- CONFIGURACIÓN DE LA PLATAFORMA FUENTE (JSF) ---
# URL de la institución ambiental
JSF_TARGET_URL=https://www.example.xxx
# Tiempo de espera máximo para carga de elementos (ms)
SCRAPING_TIMEOUT=30000 

# --- LOGGING Y DEBUG ---
# Niveles: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG
