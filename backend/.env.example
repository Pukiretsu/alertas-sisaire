LOG_LEVEL=INFO

# Portal JSF / SISAIRE
JSF_TARGET_URL=https://sisaire.ideam.gov.co/ideam-sisaire-web/consultas.xhtml
CHROMIUM_EXECUTABLE_PATH=
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=120000
DEFAULT_STATION_IDS=29586,31877,8249,31862,8254,8243,31867,31866,31865,31860

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Persistencia de sesiones/jobs
# Local sin Docker: deja vacío para SQLite en OUTPUTS_DIR/calculation_jobs.db
# Docker Compose: postgresql+psycopg://airquality:airquality@db:5432/airquality
DATABASE_URL=

# Local folders
DOWNLOADS_DIR=../downloads
OUTPUTS_DIR=../outputs
