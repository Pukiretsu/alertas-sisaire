import requests
import logging
import os

logger = logging.getLogger(__name__)


def enviar_telegram(mensaje: str):
    token = os.getenv("TELEGRAM_TOKEN")
    chat_id = os.getenv("TELEGRAM_CHAT_ID")

    if not token or not chat_id:
        logger.warning("Telegram no configurado en .env")
        return

    url = f"https://api.telegram.org/bot{token}/sendMessage"

    payload = {
        "chat_id": chat_id,
        "text": mensaje
    }

    try:
        response = requests.post(url, data=payload, timeout=10)
        response.raise_for_status()
        logger.info("Notificación enviada por Telegram")
    except Exception as e:
        logger.error(f"Error enviando Telegram: {e}")


def construir_mensaje(estacion, contaminante, estado, valor):
    return f"""
🚨 SISTEMA DE ALERTA DE CALIDAD DEL AIRE

📍 Estación: {estacion}
☣️ Contaminante: {contaminante}
📊 Estado: {estado.value}
📈 Último valor registrado: {valor}
"""


def notificar_alerta(estacion, contaminante, estado, valor):
    mensaje = construir_mensaje(estacion, contaminante, estado, valor)
    enviar_telegram(mensaje)
